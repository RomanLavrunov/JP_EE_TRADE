# TRADE ANALYSIS: EXPORTS & IMPORTS JAPAN

#1. Load necessary libraries
library(readxl)   
library(dplyr)    
library(tidyr)    
library(ggplot2)   
library(ggrepel)  
library(scales) 

#2. Load Excel file
# Load the table with exports and imports to Japan
df_tradeshare_jp_ee <- read_excel(
  "clean_data/VKK32_export_import_japan.xlsx",
  sheet = "TRD_VAL"
) %>%  
  select(year,share_of_export_for_estonia,share_of_import_for_estonia) %>% 
  mutate(
    year = as.integer(year),
    across(c(share_of_export_for_estonia,
             share_of_import_for_estonia),
           as.numeric)
  )

df_tradeshare_long <- df_tradeshare_jp_ee %>%
  pivot_longer(
    cols = c(share_of_export_for_estonia,
             share_of_import_for_estonia),  
    names_to = "type",
    values_to = "value"
  ) %>% 
  mutate(type = case_when(
    type == "share_of_export_for_estonia" ~ "Exports",
    type == "share_of_import_for_estonia" ~ "Imports"
  ))

#3. Plot the data
# Create a clean, professional plot with legend on the right
ggplot(df_tradeshare_long, aes(x = factor(year), y =value, fill = type)) +
  geom_col(position = "dodge") +
  scale_fill_manual(values = c("Exports" = "#1D3557", "Imports" = "#E63946")) +
  labs(x = "Year", y = "Share (%)", fill = "Trade Type",
       title = "Estonia Export vs Import Shares") +
  theme_minimal(base_size = 13)